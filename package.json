{
  "name": "fincontrol-flow-api",
  "version": "1.0.0",
  "description": "API RESTful para controle financeiro pessoal — FinControl Flow",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "mocha --config tests/.mocharc.yml",
    "test:report": "npm test",
    "perf:smoke": "k6 run tests/performance/smoke.js",
    "perf:smoke:report": "cross-env K6_WEB_DASHBOARD=true K6_WEB_DASHBOARD_EXPORT=reports/perf-smoke-report.html k6 run tests/performance/smoke.js",
    "perf:login": "k6 run tests/performance/login-load.js",
    "perf:login:report": "cross-env K6_WEB_DASHBOARD=true K6_WEB_DASHBOARD_EXPORT=reports/perf-login-report.html k6 run tests/performance/login-load.js",
    "perf:statement": "k6 run tests/performance/statement-load.js",
    "perf:statement:report": "cross-env K6_WEB_DASHBOARD=true K6_WEB_DASHBOARD_EXPORT=reports/perf-statement-report.html k6 run tests/performance/statement-load.js"
  },
  "keywords": [
    "fincontrol",
    "api",
    "rest",
    "express",
    "jwt"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "cross-env": "^10.1.0",
    "mocha": "^11.7.5",
    "mochawesome": "^7.1.4",
    "supertest": "^7.2.2"
  }
}
